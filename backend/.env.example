# 应用基础配置
CHEFMATE_APP_NAME='ChefMate Backend'
CHEFMATE_APP_ENV=dev
CHEFMATE_APP_DEBUG=true
CHEFMATE_API_PREFIX=/api

# 数据库连接
CHEFMATE_DATABASE_URL=mysql+pymysql://root:password@localhost:3306/chefmate

# 对象存储配置
CHEFMATE_OBJECT_STORAGE_BUCKET=chefmate-assets

# 通用大模型配置
# 后端所有大模型默认走这一套配置
CHEFMATE_LLM_BASE_URL=https://api.openai.com/v1
CHEFMATE_LLM_API_KEY=
CHEFMATE_LLM_MODEL=gpt-4.1-mini
CHEFMATE_LLM_TIMEOUT_SECONDS=60

# 图像识别后端切换
# 可选值：llm / local_model
CHEFMATE_VISION_BACKEND=llm

# 基于大模型的图像识别配置
# 如果留空，就继承上面的通用大模型配置
CHEFMATE_VISION_LLM_BASE_URL=
CHEFMATE_VISION_LLM_API_KEY=
CHEFMATE_VISION_LLM_MODEL=
CHEFMATE_VISION_LLM_TIMEOUT_SECONDS=0

# 本地自训练模型配置
# 当前先预留，后续接入你们自己的食材识别模型时使用
CHEFMATE_VISION_LOCAL_MODEL_PATH=
CHEFMATE_VISION_LOCAL_CONFIDENCE_THRESHOLD=0.35
